{
  "name": "webdriverio",
  "description": "Next-gen browser and mobile automation test framework for Node.js",
  "version": "9.30.0",
  "homepage": "https://webdriver.io",
  "author": "Christian Bromann <mail@bromann.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webdriverio/webdriverio.git",
    "directory": "packages/webdriverio"
  },
  "bugs": {
    "url": "https://github.com/webdriverio/webdriverio/issues"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "tags": [
    "webdriver",
    "selenium",
    "test",
    "automation",
    "browser",
    "javascript",
    "node"
  ],
  "keywords": [
    "webdriverio",
    "webdriver",
    "selenium",
    "appium",
    "saucelabs",
    "sauce",
    "labs",
    "mocha",
    "nodeUnit",
    "buster",
    "puppeteer",
    "vows",
    "jasmine",
    "assert",
    "cucumber",
    "testingbot"
  ],
  "main": "./build/index.cjs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "browser": "./build/index.js",
      "importSource": "./src/node.ts",
      "import": "./build/node.js",
      "requireSource": "./src/index.cts",
      "require": "./build/index.cjs"
    },
    "./scripts/*": {
      "source": "./src/scripts/*.ts",
      "import": "./build/scripts/*"
    },
    "./protocol-stub": {
      "source": "./src/protocol-stub.ts",
      "import": "./build/protocol-stub.js"
    }
  },
  "types": "./build/index.d.ts",
  "typeScriptVersion": "3.8.3",
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.4.0",
    "@types/archiver": "^8.0.0",
    "@types/aria-query": "^5.0.4",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/lodash.zip": "^4.2.9",
    "puppeteer-core": "^24.34.0",
    "safe-stable-stringify": "^2.5.0"
  },
  "dependencies": {
    "@types/node": "^26.1.1",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "@wdio/config": "workspace:*",
    "@wdio/logger": "workspace:*",
    "@wdio/protocols": "workspace:*",
    "@wdio/repl": "workspace:*",
    "@wdio/types": "workspace:*",
    "@wdio/utils": "workspace:*",
    "archiver": "^8.0.0",
    "aria-query": "^5.3.2",
    "cheerio": "1.0.0",
    "css-shorthand-properties": "^1.1.2",
    "css-value": "^0.0.1",
    "grapheme-splitter": "^1.0.4",
    "htmlfy": "^1.0.2",
    "is-plain-obj": "^4.1.0",
    "jszip": "^3.10.1",
    "lodash.clonedeep": "^4.5.0",
    "lodash.zip": "^4.2.0",
    "query-selector-shadow-dom": "^1.0.1",
    "resq": "^1.11.0",
    "rgb2hex": "0.2.5",
    "serialize-error": "^12.0.0",
    "urlpattern-polyfill": "^10.1.0",
    "webdriver": "workspace:*"
  },
  "peerDependencies": {
    "puppeteer-core": ">=22.x <25.x"
  },
  "peerDependenciesMeta": {
    "puppeteer-core": {
      "optional": true
    }
  }
